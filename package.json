{
  "name": "@tenkicloud/composio-tools",
  "version": "0.1.0",
  "description": "Tenki sandbox tools for Composio agents — boot disposable Linux microVMs, run commands, snapshot, and terminate them through Composio custom toolkits.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/live-smoke.ts",
    "agent": "tsx scripts/agent-test.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\""
  },
  "keywords": [
    "composio",
    "tenki",
    "sandbox",
    "microvm",
    "ai-agents",
    "agent-tools",
    "custom-toolkit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderArmua/composio-tools.git"
  },
  "homepage": "https://github.com/AlexanderArmua/composio-tools#readme",
  "bugs": {
    "url": "https://github.com/AlexanderArmua/composio-tools/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@composio/core": ">=0.13.0 <1"
  },
  "dependencies": {
    "@tenkicloud/sandbox": "^0.3.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@composio/core": "^0.13.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
